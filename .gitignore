!unitree_goM80106/lib/*.so

# IDE / editor
.idea/
.vscode/
# Keep shared VSCode settings
!/.vscode/settings.json
!/.vscode/c_cpp_properties.json
!/.vscode/launch.json
!/.vscode/tasks.json
.marscode/

# Runtime state (machine-local)
.can_counter.json
